# ═══════════════════════════════════════════════════════════════════════
# CHAT INNOVACLOUD — Variables de entorno
# Copia este archivo como backend/.env y ajusta los valores
# ═══════════════════════════════════════════════════════════════════════

# ── Base de datos (PostgreSQL 16 + pgvector) ──────────────────────────
# Desarrollo local: DB_HOST=localhost, DB_PORT=5433
# Docker:           DB_HOST=postgres,    DB_PORT=5432
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASS=postgres
DB_NAME=app

# ── JWT ────────────────────────────────────────────────────────────────
# Generar: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-generate-a-random-64-byte-hex-string
JWT_EXPIRES=8h

# ── Servidor ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_PORT=4200

# ── CORS ───────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma (sin espacios)
# Desarrollo: http://localhost:4200
# Producción: https://tudominio.com
CORS_ORIGINS=http://localhost:4200

# ── Content-Security-Policy (opcional) ────────────────────────────────
# Si se deja vacío se usa el valor por defecto del backend
CSP_DIRECTIVES=

# ── Resend (email transaccional) ──────────────────────────────────────
# Obtén tu API key en https://resend.com
RESEND_API_KEY=re_your-resend-api-key
MAIL_FROM=onboarding@resend.dev

# ── App ────────────────────────────────────────────────────────────────
# URL pública del backend (para enlaces en emails, etc.)
APP_URL=http://localhost:3001

# ── Google Gemini AI ──────────────────────────────────────────────────
# Obtén tu API key en https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# ── Cifrado de mensajes (AES-256-GCM) ─────────────────────────────────
# Activa cifrado para mensajes nuevos de chat y WhatsApp.
# Usa una cadena larga y privada. No la cambies luego o no podrás
# descifrar mensajes previos.
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CHAT_ENCRYPTION_KEY=change-me-use-a-64-char-hex-string

# ── WhatsApp (Baileys) ────────────────────────────────────────────────
# WhatsApp se conecta por QR con Baileys. No requiere token de Cloud API.
VERIFY_TOKEN=your-verify-token

# ── Microsoft Teams (opcional) ────────────────────────────────────────
# Solo necesario si usas integración con Teams
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=your-microsoft-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:3001/advisors-whatsapp/teams/oauth/callback
TEAMS_SHARED_CALENDAR_ID=your-teams-calendar-id
